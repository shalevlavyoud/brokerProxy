{
  "http": {
    "port": 8080,
    "host": "0.0.0.0"
  },
  "redis": {
    "host": "127.0.0.1",
    "port": 6379,
    "prefix": "bp",
    "connectTimeout": 5000,
    "commitTimeout": 5000
  },
  "topics": ["computers", "headsets", "conferences"],
  "activemq": {
    "brokerUrl": "tcp://127.0.0.1:61616"
  },
  "jms": {
    "topicPrefetch": 10,
    "maxPendingPerTopic": 100,
    "processingTimeoutMs": 5000
  },
  "retention": {
    "windowSize": 10000
  },
  "guardrails": {
    "maxDataJsonBytes": 65536,
    "maxChangesPerCommit": 1000
  }
}
