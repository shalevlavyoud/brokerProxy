{
  "$schema": "https://raw.githubusercontent.com/apache/logging-log4j2/main/log4j-layout-template-json/src/main/resources/schema/log4j2-layout-template-json-schema.json",
  "_note": "Log4j2 JsonTemplateLayout — field names mirror the previous logstash-logback-encoder output.",

  "ts": {
    "$resolver": "timestamp",
    "pattern": {
      "format": "yyyy-MM-dd'T'HH:mm:ss.SSS'Z'",
      "timeZone": "UTC"
    }
  },

  "level": {
    "$resolver": "level",
    "field": "name"
  },

  "logger": {
    "$resolver": "logger",
    "field": "name"
  },

  "thread": {
    "$resolver": "thread",
    "field": "name"
  },

  "msg": {
    "$resolver": "message",
    "stringified": true
  },

  "correlationId": {
    "$resolver": "mdc",
    "key": "correlationId"
  },

  "topic": {
    "$resolver": "mdc",
    "key": "topic"
  },

  "producerId": {
    "$resolver": "mdc",
    "key": "producerId"
  },

  "stackTrace": {
    "$resolver": "exception",
    "field": "stackTrace",
    "stackTrace": {
      "stringified": true
    }
  }
}
