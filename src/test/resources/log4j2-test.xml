<?xml version="1.0" encoding="UTF-8"?>
<!--
  Plain-text console logging for tests — avoids JSON noise in CI output
  while still exercising the full application code path.

  This file takes precedence over log4j2.xml when running tests (Log4j2
  discovers log4j2-test.xml before log4j2.xml on the test classpath).
-->
<Configuration status="WARN">

  <Appenders>
    <Console name="STDOUT" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n"/>
    </Console>
  </Appenders>

  <Loggers>
    <Logger name="io.vertx"         level="WARN"  additivity="false">
      <AppenderRef ref="STDOUT"/>
    </Logger>
    <Logger name="io.netty"         level="WARN"  additivity="false">
      <AppenderRef ref="STDOUT"/>
    </Logger>
    <Logger name="com.brokerproxy"  level="DEBUG" additivity="false">
      <AppenderRef ref="STDOUT"/>
    </Logger>

    <Root level="INFO">
      <AppenderRef ref="STDOUT"/>
    </Root>
  </Loggers>

</Configuration>
